{
    "启动FGO": {
        "action": {
            "type": "StartApp",
            "param": {
                "package": "com.aniplex.fategrandorder"
            }
        },
        "post_delay": 10000,
        "next": [
            "自动登录",
            "[JumpBack]是否要更新",
            "[JumpBack]异常启动弹窗",
            "[JumpBack]等待更新完成"
        ]
    },
    "直到达到主界面": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "main_ui.png"
                ]
            }
        },
        "post_delay": 5000,
        "timeout": 40000,
        "focus": {
            "Node.Recognition.Starting": "等待到达主界面"
        },
        "next": [
            "确认抵达主界面流程"
        ]
    },
    "自动登录": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "タッチして"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "post_delay": 5000,
        "focus": {
            "Node.Recognition.Failed": "尚未检测到登录成功"
        },
        "next": [
            "自动登录2"
        ]
    },
    "如果要SKIP": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "SKIP"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "timeout": 5000,
        "next": [
            "点击是"
        ]
    },
    "点击是": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "はい"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "timeout": 5000,
        "next": [
            "如果有奖励",
            "确认抵达主界面流程"
        ]
    },
    "如果有奖励": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "タッチして"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "next": [
            "确认抵达主界面流程"
        ]
    },
    "自动登录2": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "Touch Screen"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "post_delay": 15000,
        "next": [
            "直到达到主界面",
            "[JumpBack]如果要关闭"
        ]
    },
    "关闭主界面弹窗": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "閉じる"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "post_delay": 4000,
        "focus": {
            "Node.Action.Starting": "关闭弹窗"
        }
    },
    "最终确认抵达主界面": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "main_ui.png"
                ]
            }
        },
        "focus": {
            "Node.Recognition.Succeeded": "成功抵达主界面",
            "Node.Recognition.Failed": "未成功抵达主界面，脚本中止"
        }
    },
    "如果要关闭": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "close.png"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "timeout": 3000
    },
    "打开游戏": {
        "next": [
            "启动FGO"
        ]
    },
    "确认抵达主界面流程": {
        "post_delay": 2000,
        "next": [
            "[JumpBack]关闭主界面弹窗",
            "如果要SKIP",
            "如果有奖励",
            "[JumpBack]如果要关闭",
            "[JumpBack]登录流程持续识别",
            "最终确认抵达主界面"
        ],
        "on_error": [
            "抵达主界面错误"
        ]
    },
    "是否要更新": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "update_botton.png"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        },
        "post_delay": 5000
    },
    "等待更新完成": {
        "max_hit": 20,
        "post_delay": 5000
    },
    "异常启动弹窗": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "deny_botton.png"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {}
        }
    },
    "抵达主界面错误": {
        "action": {
            "type": "StopTask",
            "param": {}
        },
        "focus": {
            "Node.Recognition.Failed": "未成功抵达主界面，脚本中止"
        }
    },
    "登录流程持续识别": {
        "max_hit": 4,
        "post_delay": 5000
    }
}